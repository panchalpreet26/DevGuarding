# ============================================================
# DevGuardian AI - environment variables (copy to .env)
# Never commit the real .env file.
# ============================================================

# ---- Backend: server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed frontend origins for CORS
CLIENT_ORIGIN=http://localhost:5173

# ---- Backend: database ----
MONGODB_URI=mongodb://localhost:27017/devguardian

# ---- Backend: auth / sessions ----
# Long random string used to sign session JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_a_long_random_string
# Optional dedicated key for encrypting GitHub tokens (defaults to JWT_SECRET).
# ENCRYPTION_KEY=
# Where the backend redirects the browser after successful GitHub login
CLIENT_URL=http://localhost:5173

# ---- GitHub OAuth (create at https://github.com/settings/developers) ----
# Application name: DevGuardian AI
# Homepage URL: http://localhost:5173
# Authorization callback URL: http://localhost:4000/api/auth/github/callback
# Scopes requested at login: read:user, user:email, repo, read:org (private + org repos)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# ---- Optional GitHub App (org install model) ----
# Create at https://github.com/settings/apps — permissions: Contents read, Metadata read
# Setup URL: http://localhost:4000/api/auth/github/app/callback
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=your-app-slug
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Optional: fine-grained PAT with access limited to selected repos.
# When set on the BACKEND (Render), it is preferred over OAuth for GitHub API calls.
# NEVER put this in Vercel or any VITE_* variable (browser-visible).
# GITHUB_TOKEN=

# ---- AI chat (pick ONE) ----
# Google Gemini (free demo) — get a key at https://aistudio.google.com/apikey
# Add this to local .env AND to Render Environment (NOT Vercel).
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
# AI_PROVIDER=gemini

# OpenAI (paid) — optional fallback if GEMINI_API_KEY is unset
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini

# ---- Frontend (Vite: only VITE_* vars are exposed to the browser) ----
VITE_API_BASE_URL=http://localhost:4000/api

# ---- Production (set in Vercel / Render dashboards — not in git) ----
# See docs/DEPLOY.md
# Render:  NODE_ENV=production
#          CLIENT_ORIGIN=https://YOUR-APP.vercel.app
#          CLIENT_URL=https://YOUR-APP.vercel.app
#          GITHUB_CALLBACK_URL=https://YOUR-SERVICE.onrender.com/api/auth/github/callback
#          MONGODB_URI=mongodb+srv://...
# Vercel:  VITE_API_BASE_URL=https://YOUR-SERVICE.onrender.com/api
